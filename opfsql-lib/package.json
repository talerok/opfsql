{
  "name": "opfsql",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test --config test/e2e/infra/config.ts",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --external:cbor-x --minify && tsc --emitDeclarationOnly --outDir dist"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitest/coverage-v8": "^3.2.4",
    "esbuild": "^0.28.0",
    "opfs-mock": "^2.6.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "cbor-x": "^1.6.4"
  }
}
