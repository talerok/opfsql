# null-handling.slt — NULL semantics across all operators

# ============================================================================
# Setup
# ============================================================================

statement ok
CREATE TABLE t (id INTEGER PRIMARY KEY, a INTEGER, b INTEGER, s TEXT)

statement ok
INSERT INTO t VALUES (1, 10, 20, 'hello')

statement ok
INSERT INTO t VALUES (2, NULL, 30, NULL)

statement ok
INSERT INTO t VALUES (3, 40, NULL, 'world')

# ============================================================================
# NULL in comparisons — all return NULL (no match)
# ============================================================================

# = with NULL
query I nosort
SELECT id FROM t WHERE a = NULL
----

# != with NULL
query I nosort
SELECT id FROM t WHERE a != NULL
----

# < with NULL
query I nosort
SELECT id FROM t WHERE a < NULL
----

# > with NULL
query I nosort
SELECT id FROM t WHERE a > NULL
----

# <= with NULL
query I nosort
SELECT id FROM t WHERE a <= NULL
----

# >= with NULL
query I nosort
SELECT id FROM t WHERE a >= NULL
----

# ============================================================================
# IS NULL / IS NOT NULL
# ============================================================================

query I rowsort
SELECT id FROM t WHERE a IS NULL
----
2

query I rowsort
SELECT id FROM t WHERE a IS NOT NULL
----
1
3

query I rowsort
SELECT id FROM t WHERE b IS NULL
----
3

query I rowsort
SELECT id FROM t WHERE s IS NOT NULL
----
1
3

# ============================================================================
# NULL in arithmetic
# ============================================================================

query I nosort
SELECT a + b FROM t WHERE id = 1
----
30

query I nosort
SELECT a + b FROM t WHERE id = 2
----
NULL

query I nosort
SELECT a + b FROM t WHERE id = 3
----
NULL

query I nosort
SELECT a * 2 FROM t WHERE id = 2
----
NULL

query I nosort
SELECT 0 - a FROM t WHERE id = 2
----
NULL

# ============================================================================
# NULL in AND (three-valued logic)
# ============================================================================

# true AND NULL → NULL (not true, so no match)
query I nosort
SELECT id FROM t WHERE (id = 1) AND (a = NULL)
----

# false AND NULL → false
query I nosort
SELECT id FROM t WHERE (1 = 0) AND (a = NULL)
----

# NULL AND true → NULL
query I nosort
SELECT id FROM t WHERE (a = NULL) AND (id = 1)
----

# ============================================================================
# NULL in OR (three-valued logic)
# ============================================================================

# true OR NULL → true
query I nosort
SELECT id FROM t WHERE (id = 1) OR (a = NULL)
----
1

# false OR NULL → NULL (no match)
query I nosort
SELECT id FROM t WHERE (1 = 0) OR (a = NULL)
----

# NULL OR true → true
query I nosort
SELECT id FROM t WHERE (a = NULL) OR (id = 3)
----
3

# ============================================================================
# NULL in BETWEEN
# ============================================================================

# NULL input
query I nosort
SELECT id FROM t WHERE a BETWEEN 5 AND 50
----
1
3

# BETWEEN where input is NULL returns NULL
query I nosort
SELECT id FROM t WHERE a BETWEEN 0 AND 100 AND id = 2
----

# ============================================================================
# NULL in CASE
# ============================================================================

query T nosort
SELECT CASE WHEN a IS NULL THEN 'null_val' ELSE 'has_val' END FROM t ORDER BY id
----
has_val
null_val
has_val

# CASE with no matching WHEN and no ELSE returns NULL
query T nosort
SELECT CASE WHEN 1 = 0 THEN 'never' END FROM t WHERE id = 1
----
NULL

# ============================================================================
# NULL ordering
# ============================================================================

# ASC: NULLs last
query I nosort
SELECT a FROM t ORDER BY a ASC
----
10
40
NULL

# DESC: NULLs first
query I nosort
SELECT a FROM t ORDER BY a DESC
----
NULL
40
10

# ============================================================================
# NOT on NULL
# ============================================================================

# NOT NULL → NULL
query I nosort
SELECT id FROM t WHERE NOT (a = NULL)
----

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP TABLE t
