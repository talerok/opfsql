# distinct.slt — SELECT DISTINCT tests

# ============================================================================
# Setup
# ============================================================================

statement ok
CREATE TABLE data (id INTEGER PRIMARY KEY, category TEXT, val INTEGER, tag TEXT)

statement ok
INSERT INTO data VALUES (1, 'A', 10, 'x')

statement ok
INSERT INTO data VALUES (2, 'B', 20, 'x')

statement ok
INSERT INTO data VALUES (3, 'A', 10, 'y')

statement ok
INSERT INTO data VALUES (4, 'C', 30, 'x')

statement ok
INSERT INTO data VALUES (5, 'B', 20, 'y')

statement ok
INSERT INTO data VALUES (6, 'A', 40, 'x')

# ============================================================================
# DISTINCT on single column
# ============================================================================

query T rowsort
SELECT DISTINCT category FROM data
----
A
B
C

# ============================================================================
# DISTINCT on multiple columns
# ============================================================================

query TI rowsort
SELECT DISTINCT category, val FROM data
----
A|10
A|40
B|20
C|30

# ============================================================================
# DISTINCT with WHERE
# ============================================================================

query T rowsort
SELECT DISTINCT category FROM data WHERE val >= 20
----
A
B
C

# ============================================================================
# DISTINCT with NULL values
# ============================================================================

statement ok
INSERT INTO data VALUES (7, NULL, 50, 'z')

statement ok
INSERT INTO data VALUES (8, NULL, 60, 'z')

# NULL should appear once in DISTINCT
query T rowsort
SELECT DISTINCT category FROM data
----
A
B
C
NULL

# ============================================================================
# DISTINCT with JOIN
# ============================================================================

statement ok
CREATE TABLE tags (id INTEGER PRIMARY KEY, tag TEXT)

statement ok
INSERT INTO tags VALUES (1, 'x')

statement ok
INSERT INTO tags VALUES (2, 'y')

query T rowsort
SELECT DISTINCT d.category FROM data d JOIN tags t ON d.tag = t.tag WHERE t.tag = 'x'
----
A
B
C

# ============================================================================
# DISTINCT preserves correct count
# ============================================================================

query I nosort
SELECT COUNT(*) FROM (SELECT DISTINCT category FROM data WHERE category IS NOT NULL)
----
3

# ============================================================================
# Cleanup
# ============================================================================

statement ok
DROP TABLE data

statement ok
DROP TABLE tags
