statement ok
DROP TABLE source

statement ok
DROP TABLE target

statement ok
DROP TABLE filtered

statement ok
DROP TABLE names_only

statement ok
DROP TABLE doubled

statement ok
DROP TABLE categories

statement ok
DROP TABLE cat_map

statement ok
DROP TABLE summary

statement ok
DROP TABLE multi
